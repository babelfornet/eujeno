#!/usr/bin/env bash
# Auto-bootstrap launcher per Synapse.
# Primo avvio: crea .venv e installa il pacchetto (pip install -e .).
# Avvii successivi: inoltra direttamente alla CLI.
#   ./bin/synapse --help
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
VENV="$REPO_ROOT/.venv"
PY="$VENV/bin/python"

if [ ! -x "$PY" ]; then
  echo "synapse: primo avvio — creo l'ambiente virtuale in .venv…" >&2
  python3 -m venv "$VENV"
  "$PY" -m pip install --upgrade pip >/dev/null
fi

# Installa/aggiorna il pacchetto se manca il modulo (idempotente, veloce a regime).
if ! "$PY" -c "import synapse" >/dev/null 2>&1; then
  echo "synapse: installo le dipendenze (pip install -e .)…" >&2
  "$PY" -m pip install -e "$REPO_ROOT" >&2
fi

exec "$PY" -m synapse "$@"
